{
  "name": "game-kfc-pro-server",
  "version": "1.0.0",
  "description": "OFC Pineapple Poker Game Server",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node game/scorer.test.js && node game/evaluator.test.js && node game/royalty.test.js && node game/deck.test.js",
    "test:auth": "node test/auth.test.js",
    "test:ws": "node test/ws-protocol.test.js",
    "test:password-gate": "node test/password-gate.test.js",
    "qa": "npm test && npm run test:auth && npm run test:ws && npm run test:password-gate",
    "qa:soak": "node test/soak-test.js",
    "qa:report": "node test/generate-qa-report.js",
    "qa:detailed": "node test/detailed-qa-test.js",
    "qa:eval": "node test/model-evaluator.js",
    "qa:benchmark": "node test/bot-benchmark.js",
    "qa:training": "node test/generate-training.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  }
}
